{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Securities Daily Report",
  "type": "object",
  "required": [
    "run_id",
    "user_id",
    "date",
    "title",
    "coverage",
    "sectors",
    "conclusions",
    "signals",
    "noise_items",
    "trends",
    "tracking_items",
    "source_counts",
    "disclaimer"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "user_id": {"type": "string"},
    "date": {"type": "string"},
    "title": {"type": "string"},
    "coverage": {"type": "string"},
    "sectors": {"type": "array", "items": {"type": "string"}},
    "conclusions": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rank", "sentiment", "title", "summary", "sector", "score", "fact", "judgement", "sources"],
        "properties": {
          "rank": {"type": "string", "enum": ["P0", "P1", "P2", "Noise"]},
          "sentiment": {"type": "string", "enum": ["利好", "利空", "中性", "不确定"]},
          "title": {"type": "string"},
          "summary": {"type": "string"},
          "sector": {"type": "string"},
          "related_companies": {"type": "array", "items": {"type": "string"}},
          "score": {
            "type": "object",
            "required": ["sector_impact", "supply_chain_relevance", "credibility", "timeliness", "trend_value", "total"],
            "properties": {
              "sector_impact": {"type": "integer", "minimum": 1, "maximum": 5},
              "supply_chain_relevance": {"type": "integer", "minimum": 1, "maximum": 5},
              "credibility": {"type": "integer", "minimum": 1, "maximum": 5},
              "timeliness": {"type": "integer", "minimum": 1, "maximum": 5},
              "trend_value": {"type": "integer", "minimum": 1, "maximum": 5},
              "total": {"type": "integer"}
            }
          },
          "fact": {"type": "string"},
          "judgement": {"type": "string"},
          "why_it_matters": {"type": "string"},
          "impact_chain": {"type": "array", "items": {"type": "string"}, "minItems": 0},
          "trend_direction": {
            "type": "object",
            "properties": {
              "short_term": {"type": "string"},
              "mid_term": {"type": "string"},
              "verification": {"type": "array", "items": {"type": "string"}}
            }
          },
          "impact_trend_explanation": {"type": "string"},
          "p0_score_explanation": {"type": "string"},
          "watch_signal_view": {
            "type": "object",
            "properties": {
              "signal_type": {"type": "string"},
              "impact_direction": {"type": "array", "items": {"type": "string"}},
              "current_strength": {"type": "string"},
              "upgrade_condition": {"type": "string"},
              "judgement_explanation": {"type": "string"}
            }
          },
          "follow_up": {"type": "string"},
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "url", "source_tier"],
              "properties": {
                "name": {"type": "string"},
                "url": {"type": "string"},
                "source_tier": {"type": "string", "enum": ["S", "A", "B", "C", "X"]}
              }
            }
          },
          "verified": {"type": "boolean"},
          "uncertainty_note": {"type": "string"},
          "noise_reason": {"type": "string"}
        },
        "allOf": [
          {
            "if": {"properties": {"rank": {"const": "P0"}}},
            "then": {
              "required": ["impact_chain", "trend_direction", "impact_trend_explanation", "p0_score_explanation", "follow_up"],
              "properties": {
                "impact_chain": {"type": "array", "minItems": 3, "maxItems": 5},
                "trend_direction": {
                  "type": "object",
                  "required": ["short_term", "mid_term", "verification"],
                  "properties": {
                    "verification": {"type": "array", "minItems": 1}
                  }
                },
                "impact_trend_explanation": {"type": "string", "minLength": 1},
                "p0_score_explanation": {"type": "string", "minLength": 1},
                "follow_up": {"type": "string", "minLength": 1}
              }
            }
          },
          {
            "if": {"properties": {"rank": {"const": "P1"}}},
            "then": {
              "required": ["watch_signal_view"],
              "properties": {
                "watch_signal_view": {
                  "type": "object",
                  "required": ["signal_type", "impact_direction", "current_strength", "upgrade_condition", "judgement_explanation"],
                  "properties": {
                    "signal_type": {"type": "string", "minLength": 1},
                    "impact_direction": {"type": "array", "minItems": 2, "maxItems": 5},
                    "current_strength": {"type": "string", "minLength": 1},
                    "upgrade_condition": {"type": "string", "minLength": 1},
                    "judgement_explanation": {"type": "string", "minLength": 1}
                  }
                }
              }
            }
          }
        ]
      }
    },
    "noise_items": {"type": "array", "items": {"type": "object", "required": ["item", "reason"]}},
    "trends": {
      "type": "object",
      "required": ["by_sector", "resonance_points", "divergence_points"],
      "properties": {
        "by_sector": {"type": "object"},
        "resonance_points": {"type": "array", "items": {"type": "string"}},
        "divergence_points": {"type": "array", "items": {"type": "string"}}
      }
    },
    "tracking_items": {"type": "array", "items": {"type": "object"}},
    "source_counts": {"type": "array", "items": {"type": "object"}},
    "disclaimer": {"type": "string", "minLength": 1}
  }
}
